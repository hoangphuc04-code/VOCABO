# ============================================================
# VOCABO — Environment Variables Template
# ============================================================
# SAO CHÉP file này thành `.env` và điền giá trị thực
# File `.env` đã được thêm vào .gitignore — KHÔNG commit lên git
# ============================================================

# ── Groq AI (bắt buộc) ──────────────────────────────────────
# Lấy miễn phí tại: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# ── Pixabay (tùy chọn — ảnh minh họa từ vựng) ───────────────
# Lấy miễn phí tại: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_key_here

# ── Cloudinary (upload ảnh avatar) ──────────────────────────
# Lấy tại: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# ── Google Sign-In (Web Client ID) ──────────────────────────
# Lấy từ google-services.json → client_type: 3 → client_id
GOOGLE_SERVER_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# ── Firebase (thông tin project) ────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app

# ── Debug ────────────────────────────────────────────────────
DEBUG=false
