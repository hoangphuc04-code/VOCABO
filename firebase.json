{
  "hosting": {
    "public": "frontend/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run lint"]
    }
  ],
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "vocabofinalapp",
          "appId": "1:1060637668034:android:1251eee3136c33b6de015b",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "vocabofinalapp",
          "configurations": {
            "android": "1:1060637668034:android:1251eee3136c33b6de015b",
            "ios": "1:1060637668034:ios:e60af2ad6ba0709cde015b",
            "macos": "1:1060637668034:ios:e60af2ad6ba0709cde015b",
            "web": "1:1060637668034:web:e02e11427a579b9ede015b"
          }
        }
      }
    }
  }
}
