# VOCABO Backend — Environment Variables
# Copy file này thành .env và điền giá trị thực

# App
SECRET_KEY=vocabo-secret-key-change-in-production
DEBUG=true
PORT=8000

# Firebase (client-side config — không phải Admin SDK)
# Lấy từ Firebase Console > Project Settings > Your apps

# AI
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=vocabo_avatars

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@vocabo.com,vocaboadmin@gmail.com
